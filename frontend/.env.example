# Base da API em produção/staging (ex.: https://api.pethotel.com). Vazio = mesma origem.
VITE_API_BASE_URL=

# Alvo do proxy do Vite em desenvolvimento.
VITE_API_PROXY_TARGET=http://localhost:5131

# --- Observabilidade (Sentry) ---
# DSN do projeto. VAZIO = observabilidade desligada (no-op). Defina só em staging/prod.
VITE_SENTRY_DSN=
# Ambiente reportado nos eventos (ex.: production, staging). Default: modo do build.
VITE_SENTRY_ENVIRONMENT=
# Versão/release para correlacionar eventos com o deploy (opcional).
VITE_APP_VERSION=
# Amostragem de tracing/Web Vitals (0..1). Default 0.1.
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
# Amostragem de Session Replay em sessões normais (0..1). Em erro, sempre grava. Default 0.1.
VITE_SENTRY_REPLAYS_SAMPLE_RATE=0.1
